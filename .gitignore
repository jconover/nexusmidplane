target/
*.class
*.jar
*.war
*.ear
.mvn/wrapper/maven-wrapper.jar

# ── .NET ─────────────────────────────────────────────────────
bin/
obj/
publish/
*.user
*.suo
.vs/
*.nupkg

# ── Docker ───────────────────────────────────────────────────
docker-compose.override.yml
docker/certs/*.crt
docker/certs/*.key
docker/certs/*.pem
docker/certs/*.p12

